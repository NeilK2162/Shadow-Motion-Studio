{
  "name": "shadow-motion-studio",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "render": "tsx src/renderer/render-cli.ts",
    "server": "tsx src/server/index.ts",
    "build:remotion": "tsx scripts/bundle-remotion.mjs",
    "build:electron-main": "node scripts/build-electron-main.mjs",
    "app:build": "npm run build && npm run build:remotion && npm run build:electron-main",
    "app": "npm run app:build && electron dist-electron/main.cjs",
    "package": "npm run app:build && electron-builder --win portable",
    "test:director": "tsx --test src/director/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@remotion/player": "^4.0.272",
    "@remotion/renderer": "^4.0.272",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "openai": "^6.39.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.272",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.272",
    "@remotion/cli": "^4.0.272",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.shadowowner.motionstudio",
    "productName": "Shadow Motion Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "dist-remotion",
        "to": "dist-remotion"
      }
    ],
    "asarUnpack": [
      "**/node_modules/@remotion/compositor-*/**"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "artifactName": "ShadowMotionStudio-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "ShadowMotionStudio-${version}-portable.${ext}"
    }
  }
}
